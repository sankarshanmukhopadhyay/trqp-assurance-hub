{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/trqp-assurance_hub/combined-assurance-manifest.schema.json",
  "title": "Combined Assurance Manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "generated_at",
    "build_id",
    "target",
    "version_tuple",
    "artifacts"
  ],
  "properties": {
    "manifest_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "build_id": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "version_tuple": {
      "type": "object",
      "required": [
        "hub",
        "conformance_suite",
        "tspp"
      ],
      "properties": {
        "hub": {
          "type": "string"
        },
        "conformance_suite": {
          "type": "string"
        },
        "tspp": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "level",
          "required",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "level": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
