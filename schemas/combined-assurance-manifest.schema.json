{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/trqp-assurance_hub/combined-assurance-manifest.schema.json",
  "title": "Combined Assurance Manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "generated_at",
    "build",
    "tools",
    "artifacts",
    "generator"
  ],
  "properties": {
    "manifest_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "build": {
      "type": "object",
      "required": [
        "build_id",
        "target"
      ],
      "properties": {
        "build_id": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        },
        "ci_run_url": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "tools": {
      "type": "object",
      "required": [
        "trqp_conformance_suite",
        "trqp_tspp"
      ],
      "properties": {
        "trqp_conformance_suite": {
          "type": "object",
          "required": [
            "version",
            "profile_id",
            "run_id"
          ],
          "properties": {
            "version": {
              "type": "string"
            },
            "profile_id": {
              "type": "string"
            },
            "run_id": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "trqp_tspp": {
          "type": "object",
          "required": [
            "version",
            "assurance_level",
            "run_id"
          ],
          "properties": {
            "version": {
              "type": "string"
            },
            "assurance_level": {
              "type": "string"
            },
            "run_id": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path",
          "produced_by",
          "media_type",
          "format",
          "notes",
          "sha256"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "produced_by": {
            "type": "string"
          },
          "media_type": {
            "type": "string"
          },
          "format": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "generator": {
      "type": "object",
      "required": [
        "name",
        "uri"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
