{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/trqp_assurance_hub/schemas/lifecycle-assertion.schema.json",
  "title": "TRQP Lifecycle Assertion",
  "type": "object",
  "required": ["type", "id", "subject", "state", "issued_at"],
  "additionalProperties": false,
  "properties": {
    "type": {"const": "TRQPLifecycleAssertion"},
    "id": {"type": "string", "minLength": 1},
    "subject": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string"}
      }
    },
    "state": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "suspended",
        "deprecated",
        "revoked",
        "retired"
      ],
      "description": "Current lifecycle state of the subject within the declared scope."
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "domain": {"type": "string"},
        "jurisdictions": {"type": "array", "items": {"type": "string"}},
        "policy_refs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "effective_from": {"type": "string"},
    "effective_to": {"type": "string"},
    "reason": {"type": "string"},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "ref"],
        "additionalProperties": false,
        "properties": {
          "kind": {"type": "string"},
          "ref": {"type": "string"}
        }
      }
    },
    "issued_at": {"type": "string"},
    "signature": {"type": "object", "additionalProperties": true}
  }
}
