{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/trqp_assurance_hub/trqp-assurance-profile.schema.json",
  "title": "TRQP Assurance Profile (Candidate)",
  "type": "object",
  "required": [
    "profile_version",
    "profile_id",
    "published_at",
    "subject",
    "assurance",
    "evidence_expectations",
    "governance"
  ],
  "properties": {
    "profile_version": {
      "type": "string",
      "description": "Version of this profile document format."
    },
    "profile_id": {
      "type": "string",
      "description": "Stable identifier for this profile instance (publisher-defined)."
    },
    "published_at": {
      "type": "string",
      "description": "ISO-8601 timestamp when this profile was published."
    },
    "subject": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "registry_base_url": { "type": "string" },
        "operator": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "contact": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "assurance": {
      "type": "object",
      "required": ["assurance_level"],
      "properties": {
        "assurance_level": {
          "type": "string",
          "enum": ["AL1", "AL2", "AL3", "AL4"],
          "description": "Assurance tier claimed by the operator."
        },
        "profile_family": {
          "type": "string",
          "description": "Optional mapping to adopter-facing labels (e.g., Minimal/Standard/High-Assurance)."
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "object",
      "description": "Optional control objectives declared in-scope for this profile.",
      "properties": {
        "in_scope": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Control IDs (e.g., TRQPAH-EVD-01)."
        },
        "control_catalog_url": {
          "type": "string",
          "description": "Pointer to the control catalog used (defaults to this repo's catalog)."
        }
      },
      "additionalProperties": false
    },
    "evidence_expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["artifact", "expectation"],
        "properties": {
          "artifact": { "type": "string" },
          "expectation": { "type": "string", "enum": ["required", "recommended", "optional"] },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "governance": {
      "type": "object",
      "required": ["versioning", "retention"],
      "properties": {
        "versioning": {
          "type": "object",
          "properties": {
            "compatibility_policy": { "type": "string" },
            "version_tuple_required": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "retention": {
          "type": "object",
          "properties": {
            "policy_url": { "type": "string" },
            "minimum_days": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "redaction": {
          "type": "object",
          "properties": {
            "redaction_report_required": { "type": "boolean" },
            "policy_url": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "recognition": {
      "type": "object",
      "description": "Optional recognition declarations and evidence hooks.",
      "properties": {
        "assertions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "subject", "basis"],
            "properties": {
              "type": { "type": "string", "description": "Publisher-defined recognition type." },
              "subject": { "type": "string", "description": "What is recognized (e.g., registry/operator/authority)." },
              "basis": { "type": "string", "description": "Why it is recognized (policy, audit, trust framework, etc.)." },
              "evidence": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Pointers to evidence artifacts (URIs or build-artifact references)."
              }
            },
            "additionalProperties": false
          }
        },
        "assertion_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional pointers to standalone Recognition Assertion artifacts."
        }
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "description": "Optional lifecycle state pointers and expectations.",
      "properties": {
        "lifecycle_policy_url": { "type": "string" },
        "current_state": {
          "type": "string",
          "enum": ["planned", "active", "suspended", "deprecated", "terminated"]
        },
        "assertion_ref": {
          "type": "string",
          "description": "Optional pointer to a standalone Lifecycle Assertion artifact."
        }
      },
      "additionalProperties": false
    },
    "discovery": {
      "type": "object",
      "description": "Optional discovery pointers and capability declarations (non-normative).",
      "properties": {
        "metadata_url": { "type": "string" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "mappings": {
      "type": "object",
      "description": "Optional ecosystem mapping declarations (e.g., VC ecosystem integration).",
      "properties": {
        "credential_ecosystem": { "type": "string" },
        "mapping_profile_url": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
