{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/trqp-assurance_hub/schemas/recognition-assertion.schema.json",
  "title": "TRQP Recognition Assertion",
  "type": "object",
  "required": ["type", "id", "issuer", "subject", "recognition", "issued_at"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "TRQPRecognitionAssertion"
    },
    "id": {
      "type": "string",
      "description": "Stable identifier for this assertion (URI or URN recommended).",
      "minLength": 1
    },
    "issuer": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string"},
        "contact": {"type": "string"}
      }
    },
    "subject": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string"}
      }
    },
    "recognition": {
      "type": "object",
      "required": ["relationship", "scope"],
      "additionalProperties": false,
      "properties": {
        "relationship": {
          "type": "string",
          "enum": ["recognizes", "does_not_recognize", "recognizes_with_conditions", "revoked"],
          "description": "Relationship statement from issuer to subject."
        },
        "scope": {
          "type": "object",
          "required": ["domain"],
          "additionalProperties": false,
          "properties": {
            "domain": {
              "type": "string",
              "description": "Trust domain / ecosystem / market boundary in which recognition is asserted.",
              "minLength": 1
            },
            "jurisdictions": {
              "type": "array",
              "items": {"type": "string"}
            },
            "credential_types": {
              "type": "array",
              "items": {"type": "string"}
            },
            "policy_refs": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "conditions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Optional human/machine readable conditions for conditional recognition."
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "ref"],
            "additionalProperties": false,
            "properties": {
              "kind": {"type": "string"},
              "ref": {"type": "string"}
            }
          },
          "description": "References to evidence artifacts supporting the recognition decision."
        },
        "lifecycle_assertion_ref": {
          "type": "string",
          "description": "Optional reference to a lifecycle assertion artifact that contextualizes this recognition."
        },
        "revocation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "revoked": {"type": "boolean"},
            "revoked_at": {"type": "string"},
            "reason": {"type": "string"}
          }
        }
      }
    },
    "issued_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when issued."
    },
    "expires_at": {
      "type": "string",
      "description": "Optional ISO 8601 expiry timestamp."
    },
    "signature": {
      "type": "object",
      "description": "Optional detached or enveloped signature block.",
      "additionalProperties": true
    }
  }
}
